# ── Required ───────────────────────────────────────────────────────────────────
# JWT from https://developer.clashroyale.com — must be whitelisted for your IP.
CR_API_TOKEN=your_token_here

# ── Clan ───────────────────────────────────────────────────────────────────────
# Clan tag (include the #).
CLAN_TAG=#PJ8Q8P

# ── Discord ────────────────────────────────────────────────────────────────────
# Incoming webhook URL from your Discord server channel settings.
# Leave blank to suppress Discord output and log to console only.
DISCORD_WEBHOOK=

# ── Storage ────────────────────────────────────────────────────────────────────
# Path to the SQLite database file (relative or absolute).
DB_PATH=bootbot.db

# ── Clash day boundary (UTC) ─────────────────────────────────────────────────
# River race "today" is computed from UTC using this reset time.
# Default 10:00 UTC preserves prior behavior.
CLASH_RESET_UTC_HOUR=10
CLASH_RESET_UTC_MINUTE=0

# ── Permanently exempt members ────────────────────────────────────────────────
# Comma-separated player tags (include the #) that will NEVER be flagged for
# boot or demotion — regardless of participation.  Intended for clan founders
# and owners.  Leave blank if no one is exempt.
EXEMPT_MEMBERS=#20Y9GRL0,#P9YYQC9Q

# ── Boot / demotion rules ──────────────────────────────────────────────────────
# Expected number of decks each member should play per war day.
MIN_DECKS_PER_DAY=4

# Flag a member if their cumulative decks used falls below this fraction of
# the expected total (e.g. 0.5 = below 50% of expected decks).
MIN_PARTICIPATION_PCT=0.5

# ── Clan size guard ────────────────────────────────────────────────────────────
# Never boot (remove from clan) members if doing so would put the clan at or
# below this number.  Demotions (co-leader → elder, elder → member) are NOT
# affected by this guard — only outright boots of member-role players are held.
# Under-performing members who are protected are shown as a yellow "Watch List"
# in the Discord report so you know who to action once recruiting improves.
MIN_CLAN_SIZE=40

# ── Report options ─────────────────────────────────────────────────────────────
# Number of distinct fame tiers to highlight in the Top Performers shoutout.
TOP_PERFORMERS_N=3

# Set to false to disable the orange boat-attack shaming embed.
# Boat attacks earn only 125 fame/tower vs 200-250 for regular/dual battles.
REPORT_BOAT_ATTACKS=true
