# Clash Royale Boot Bot
# Copy this file to .env and fill in your values.

# ------------------------------------------------------------------
# Required
# ------------------------------------------------------------------

# Your clan tag (include the #)
CLAN_TAG=#PJ8Q8P

# Clash Royale API token (https://developer.clashroyale.com/)
CR_API_TOKEN=your_token_here

# Discord webhook URLs — DEV is used by default; PROD is used when ENVIRONMENT=production
DISCORD_WEBHOOK_DEV=https://discord.com/api/webhooks/...
DISCORD_WEBHOOK_PROD=https://discord.com/api/webhooks/...

# ------------------------------------------------------------------
# Optional — defaults shown
# ------------------------------------------------------------------

# Set to "production" to post to DISCORD_WEBHOOK_PROD instead of DEV
# ENVIRONMENT=production

# SQLite database file path
DB_PATH=boot-bot.db

# Where to store raw JSON archives and timestamped log directories.
# LOG_DIR=logs creates files in:
#   logs/ingest/20260327T100000Z_ingest.log
#   logs/report/20260327T100500Z_report.log
DATA_DIR=data
LOG_DIR=logs

# Minimum decks a member must use on a war day to avoid being flagged
MIN_DECKS_PER_DAY=4

# Rolling war-day window and max entries shown for worst/best performer sections
WORST_PERFORMERS_DAYS=16
WORST_PERFORMERS_SHOW=10
BEST_PERFORMERS_DAYS=16
BEST_PERFORMERS_SHOW=10

# Comma-separated tags that are never flagged (e.g. clan owner)
EXEMPT_TAGS=#OWNER1,#OWNER2
